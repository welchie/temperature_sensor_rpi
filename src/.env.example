# URL where temperature data is sent (exclude endpoint path '/sensordata/create')
SENSOR_DATA_URL=http://localhost

# Sensor Device Configuration
SENSOR_DEVICE_ID=28-XXXXXXXXXXXX
SENSOR_DEVICE_NAME=Device Name

# Read interval in seconds (default is 360 seconds = 6 minutes)
SENSOR_READ_INTERVAL=360

# HTTP Basic Authentication Credentials (optional, fallback to default user:password if omitted)
# SENSOR_AUTH_USER=user
# SENSOR_AUTH_PASSWORD=password

# Log level config (DEBUG, INFO, WARNING, ERROR)
# SENSOR_LOG_LEVEL=INFO

# Base directory override for the 1-wire devices path (useful for local development and mock testing)
# SENSOR_BASE_DIR=/sys/bus/w1/devices/
